<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.BrazaleteApp" parent="Theme.Material3.Light.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/app_electric_blue</item>
        <item name="colorPrimaryContainer">@color/app_indigo</item>
        <item name="colorSecondary">@color/app_violet</item>
        <item name="colorTertiary">@color/app_lavender</item>
        <item name="colorSurface">@color/app_cold_white</item>
        <item name="colorOnSurface">@color/app_navy_deep</item>
        <item name="android:windowBackground">@drawable/bg_app</item>
        <item name="android:statusBarColor">@color/app_navy_deep</item>
        <item name="android:navigationBarColor">@color/app_cold_white</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <style name="Theme.BrazaleteApp" parent="Base.Theme.BrazaleteApp" />

    <style name="ShapeAppearanceOverlay_BrazaleteApp_Circle">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
</resources>
