<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/app_lavender"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtContactoNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/app_navy_deep"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtContactoNumero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/app_indigo"
                android:textSize="13sp" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/btnEliminarContacto"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_circle_coral"
            android:contentDescription="Eliminar contacto"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_minus" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
