<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#101820"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/mainContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/txtTitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Brazalete Bluetooth"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/txtEstado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No conectado"
            android:textColor="#D6D6D6"
            android:textSize="18sp"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnConectar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Conectar al HC-05"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/txtSenal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="-"
            android:textColor="#00FF66"
            android:textSize="120sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/txtUltimoDato"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Esperando señal..."
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:gravity="center"
            android:layout_marginBottom="28dp" />

        <TextView
            android:id="@+id/txtContactosTitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Contactos de emergencia"
            android:textColor="#FFFFFF"
            android:textSize="21sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/txtContactosInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Agrega o selecciona los contactos que recibirán el SMS con tu ubicación exacta."
            android:textColor="#CFCFCF"
            android:textSize="15sp"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/edtTelefono"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ej: +593991234567"
            android:inputType="phone"
            android:textColor="#FFFFFF"
            android:textColorHint="#9E9E9E"
            android:backgroundTint="#00FF66"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnAgregarContacto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Agregar contacto manualmente"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnSeleccionarContacto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Seleccionar desde contactos"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnLimpiarContactos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Limpiar contactos"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/txtListaContactos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No hay contactos agregados."
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:background="#1A2A33"
            android:padding="14dp" />

    </LinearLayout>

</ScrollView>